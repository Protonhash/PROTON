# Server
PORT=3001
HOST=0.0.0.0

# Database
DATABASE_URL=postgresql://proton:proton@localhost:5432/proton

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-this-to-a-random-secret-in-production

# Mining
TASK_TIMEOUT_MS=30000
MIN_HASHRATE=1000
EPOCH_DURATION_SECONDS=3600

# Referral
REFERRAL_BONUS_PERCENT=5

# Fee - Owner wallet collects % from all mining rewards
OWNER_WALLET=YOUR_SOLANA_WALLET_ADDRESS
OWNER_FEE_PERCENT=10
OWNER_SECRET=change-this-to-admin-secret

# Token Claim (set after pump.fun launch)
PROTON_TOKEN_MINT=
PROTON_DECIMALS=6
CLAIM_RATE=1000
CLAIM_MIN_POINTS=100
CLAIM_COOLDOWN_MS=3600000
CLAIM_ENABLED=false
CLAIM_WALLET_PRIVATE_KEY=
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
